#!/bin/sh
# Pre-commit guard: block key material, run gitleaks when available,
# and keep Rust formatting clean. Enable once per clone with:
#   git config core.hooksPath .githooks

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

blocked=""
for f in $staged; do
  case "$f" in
    *.key|*.pem|*.keystore|*.keystore.b64|*.p12|*.pfx) blocked="$blocked $f" ;;
  esac
done
if [ -n "$blocked" ]; then
  echo "pre-commit: refusing to commit key material:$blocked" >&2
  exit 1
fi

if git diff --cached -- . ':!*.lock' | grep -qE 'BEGIN (RSA |EC |OPENSSH |)?PRIVATE KEY'; then
  echo "pre-commit: staged content contains a private key block" >&2
  exit 1
fi

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact || exit 1
fi

if [ -f Cargo.toml ] && command -v cargo >/dev/null 2>&1; then
  cargo fmt --all -- --check || { echo "pre-commit: formatting drift, run 'cargo fmt --all'" >&2; exit 1; }
fi

exit 0
